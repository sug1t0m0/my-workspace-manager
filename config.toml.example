# wsm (Workspace Manager) のマシン設定の例。wsm-server が読む (ホストのみに配置)。
# 実ファイルは ~/.config/wsm/config.toml (XDG_CONFIG_HOME 準拠) に置く。
# 同名の環境変数 (WSM_SESSION_MANAGER 等) はその場のオーバーライドとして優先される。
# docs/wsm.md の Settings 節を参照。

# セッションマネージャーの列挙 (バイナリの絶対パス、チルダ可)。
# ファイルでの出現順が選択 UI の並び順。
# パスを設定していないマネージャーは選択不能 (フォールバックはない)。
herdr_path = "~/.local/bin/herdr"
tmux_path = "/opt/homebrew/bin/tmux"

# 既定のセッションマネージャー (未指定なら列挙の先頭)
default_session_manager = "herdr"

# 既定のトラッカー (未指定なら [[tracker]] の列挙の先頭)
# default_tracker = "github"

# フォールバック devcontainer 設定 (リポジトリに devcontainer.json がないときの既定)
default_devcontainer_config = "/path/to/your/default/.devcontainer/devcontainer.json"

# worktree の置き場 (既定: ~/worktrees)
# worktree_root = "~/worktrees"

# 🐳 ウィンドウで docker exec するシェル (既定: zsh)
# devcontainer_shell = "zsh"

# --- テーブルは末尾にまとめる ---
# TOML の意味論上、[[...]] テーブルより後ろに置いたトップレベルキーは
# テーブルのキーと解釈されるため、以降にトップレベルキーを足さないこと。

# Tracker プラグインのインスタンスの列挙 (docs/wsm.md「Tracker プラグイン契約」)。
# 列挙したものだけが存在する (フォールバックはない)。同じバイナリを別名・
# 別設定で複数登録できる (例: 個人用と organization 用)。
# 予約キー (name / path / ns) 以外は WSM_TRACKER_<KEY大文字> の環境変数として
# プラグインに渡る (owner → WSM_TRACKER_OWNER)。
# github-api = GraphQL 直叩き + gh 認証。sub-issues (階層) 対応の推奨版。
# gh CLI 版 (~/.local/bin/wsm-tracker-github) もある (階層なし)。
[[tracker]]
name = "github"
path = "~/.local/bin/wsm-tracker-github-api"

# organization 用のインスタンスの例:
# [[tracker]]
# name = "github-acme"
# path = "~/.local/bin/wsm-tracker-github-api"
# owner = "acme-corp"          # → WSM_TRACKER_OWNER (repo-group の照会先)
# ns = "acme-corp,acme-labs"   # この ns のリポジトリの既定トラッカーになる

# ghq 管理外のリポジトリの登録 (複数可)。識別子は <ns>/<name> になり、
# worktree は <worktree_root>/<host>/<ns>/<name>/<id> に作られる (ghq のものと共通)。
# ns/name は ghq のリポジトリも含めて全体で一意であること (重複はエラー)。
# [[repo]]
# path = "~/work/aaa"          # クローン本体の場所 (必須)
# host = "gitlab.example.com"  # worktree パス導出に使う host (必須)
# ns   = "myteam"              # 識別子の namespace (必須)
# name = "aaa"                 # 識別子のリポジトリ名 (省略時 path の basename)
# tracker = "github"           # 使うトラッカー名 (省略時 default_tracker)
