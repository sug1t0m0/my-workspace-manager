#!/usr/bin/env zsh
# wsm: Workspace Manager UI
# fzf による対話的選択・表示整形と、ホストでのターミナル連携 (Terminal アダプタ)
# を担う。状態の照会・変更はすべて wsm-server (JSON API) に委譲する。
# ホスト・DevContainer 共通の単一実装で、wsm-server への到達方法 (transport)
# だけが実行環境で変わる。

set -euo pipefail

# --- Transport ---
# local: wsm-server が PATH にある環境 (ホスト) で直接実行する
# ssh:   ホストの wsm-server を SSH 越しに呼ぶ (DevContainer)
# WSM_TRANSPORT で明示指定がなければ wsm-server の有無で自動判別する。

WSM_HOST="${WSM_HOST:-host.docker.internal}"
HOST_USER="${HOST_USER:-}"
HOST_SSH_KEY="${HOST_SSH_KEY:-devcontainer}"
SSH_OPTS=(-F /dev/null -o StrictHostKeyChecking=no -o LogLevel=ERROR -o IdentityFile=~/.ssh/"$HOST_SSH_KEY")

if [[ -z "${WSM_TRANSPORT:-}" ]]; then
  if command -v wsm-server >/dev/null 2>&1; then
    WSM_TRANSPORT=local
  else
    WSM_TRANSPORT=ssh
  fi
fi

_server() {
  case "$WSM_TRANSPORT" in
    local)
      wsm-server "$@"
      ;;
    ssh)
      local cmd="wsm-server"
      local arg
      for arg in "$@"; do
        cmd+=" $(printf '%q' "$arg")"
      done
      ssh "${SSH_OPTS[@]}" "${HOST_USER}@${WSM_HOST}" "$cmd"
      ;;
    *)
      echo "Error: invalid WSM_TRANSPORT: $WSM_TRANSPORT" >&2
      exit 1
      ;;
  esac
}

# WSM_SESSION_MANAGER が SSH 越しの wsm-server には伝わらないことの注意喚起
_warn_manager_over_ssh() {
  echo "Warning: -m/--manager は SSH 経由では反映されません (ホスト側の既定を使用)" >&2
}

# --- Dependency checks ---

_check_deps() {
  local missing=()
  command -v fzf >/dev/null 2>&1 || missing+=(fzf)
  command -v jq >/dev/null 2>&1 || missing+=(jq)

  if [[ "$WSM_TRANSPORT" == "ssh" ]]; then
    command -v ssh >/dev/null 2>&1 || missing+=(ssh)
    if [[ -z "$HOST_USER" ]]; then
      echo "Error: HOST_USER is not set" >&2
      exit 1
    fi
    if [[ ! -f ~/.ssh/"$HOST_SSH_KEY" ]]; then
      echo "Error: SSH key not found: ~/.ssh/$HOST_SSH_KEY" >&2
      exit 1
    fi
  fi

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Error: missing dependencies: ${missing[*]}" >&2
    exit 1
  fi
}

# --- Target 解決 ---
# "<ns>/<repo>#<id>" または bare "<id>" を受け取り "<ns_repo>\t<id>" を返す。
# bare 形式はカレントディレクトリの git remote (origin) から解決するため、
# core ではなく UI 層の責務 (worktree 内でも正しく動作する)。
_resolve_target() {
  local arg=$1
  if [[ "$arg" == *"#"* ]]; then
    local ns_repo=${arg%#*}
    local id=${arg#*#}
    if [[ "$ns_repo" != */* || -z "$id" ]]; then
      echo "Error: invalid form. Use <ns>/<repo>#<id>." >&2
      return 1
    fi
    printf '%s\t%s\n' "$ns_repo" "$id"
  else
    # remote URL の末尾 <ns>/<repo> を host によらず取り出す
    # (git@host:ns/repo.git / https://host/ns/repo.git / ssh://... に対応)。
    # host の解決は server の RepoStore が行うため、ここでは識別子だけでよい
    local ns_repo
    ns_repo=$(git remote get-url origin 2>/dev/null | sed -E 's|\.git$||; s|^.*[:/]([^/]+/[^/]+)$|\1|')
    if [[ -z "$ns_repo" ]]; then
      echo "Error: not in a git repository. Use 'wsm <op|rm>' (interactive) or pass <ns>/<repo>#<id>." >&2
      return 1
    fi
    printf '%s\t%s\n' "$ns_repo" "$arg"
  fi
}

# --- Terminal アダプタ ---
# open 後にセッションへアタッチしたタブを端末エミュレーターに開かせる。
# アタッチ用コマンドは core の open 応答 (attach_command) から受け取り、
# UI はセッションマネージャー実装を知らない。
# 現在の実装は Ghostty (macOS)。SSH transport (DevContainer) では
# アタッチできないため何もしない。

_terminal_available() {
  [[ "$WSM_TRANSPORT" == "local" && "$OSTYPE" == darwin* ]]
}

_open_terminal_tab() {
  local command=$1

  osascript \
    -e 'on run argv' \
    -e '  set terminalCommand to item 1 of argv' \
    -e '  tell application "Ghostty"' \
    -e '    set cfg to new surface configuration from {command:terminalCommand}' \
    -e '    if (count windows) is 0 then' \
    -e '      set w to new window with configuration cfg' \
    -e '    else' \
    -e '      set t to new tab in window 1 with configuration cfg' \
    -e '      select tab t' \
    -e '    end if' \
    -e '  end tell' \
    -e 'end run' \
    "$command"
}

# --- UI parts ---

# サーバーの設定 (tmux_path / herdr_path) に列挙されたものだけを、設定の
# 並び順で出す。先頭が既定。
_pick_session_manager() {
  local json=$(_server list-session-managers)
  local items=()
  local name is_default
  while IFS=$'\t' read -r name is_default; do
    [[ -n "$name" ]] || continue
    local display=$name
    [[ "$is_default" == "true" ]] && display+="  (既定)"
    items+=("${name}"$'\t'"${display}")
  done < <(printf '%s\n' "$json" | jq -r '.[] | "\(.name)\t\(.default)"')
  if [[ ${#items[@]} -eq 0 ]]; then
    echo "Error: no session manager configured (set tmux_path / herdr_path in config.toml)" >&2
    return 1
  fi
  local selected=$(printf '%s\n' "${items[@]}" \
    | fzf --with-nth=2.. --delimiter=$'\t' --height=40% --reverse --prompt="Session manager> ")
  [[ -n "$selected" ]] && printf '%s\n' "$selected" | cut -f1
}

# Format devcontainer state into a display indicator.
_dc_indicator() {
  case "$1" in
    running) echo "🟢 dev" ;;
    stopped) echo "🔴 dev" ;;
    *)       echo "" ;;
  esac
}

# Step 1: repo-group 選択 (リポジトリのグルーピング。GitHub では Projects)。
# server が全トラッカーを束ねて返すので、複数トラッカーのときだけ
# インスタンス名を前置して世界を区別する。返り値は "tracker\tgroup_id"。
_pick_repo_group() {
  local TAB=$'\t'

  local json=$(_server list-repo-groups)
  local items=()

  local multi=$(printf '%s\n' "$json" | jq '[.[].tracker] | unique | length > 1')
  local groups=$(printf '%s\n' "$json" | jq -r '.[] | "\(.tracker)\t\(.id)\t\(.title)"')
  if [[ -n "$groups" ]]; then
    local tracker id title
    while IFS=$'\t' read -r tracker id title; do
      local display=$title
      [[ "$multi" == "true" ]] && display="(${tracker}) ${title}"
      items+=("${tracker}${TAB}${id}${TAB}${display}")
    done <<< "$groups"
  fi

  items+=("-${TAB}none${TAB}(グループなし: 全リポジトリ)")

  local selected=$(printf '%s\n' "${items[@]}" \
    | fzf --with-nth=3.. --delimiter=$'\t' --height=40% --reverse --prompt="Repo group> ")
  if [[ -n "$selected" ]]; then
    printf '%s\n' "$selected" | cut -f1,2
  fi
}

# Step 2: リポジトリ選択
_pick_repo() {
  local group_id=$1
  local TAB=$'\t'

  local json=$(_server list-repos --group "$group_id")
  local count=$(printf '%s\n' "$json" | jq 'length')

  if [[ "$count" -eq 0 ]]; then
    echo "No repositories found" >&2
    return 1
  fi

  local items=()
  while IFS=$'\t' read -r repo active_count; do
    local display="${repo}"
    if [[ "$active_count" -gt 0 ]]; then
      display+="  (${active_count} workspaces)"
    fi
    items+=("${repo}${TAB}${display}")
  done < <(printf '%s\n' "$json" | jq -r '.[] | "\(.ns_repo)\t\(.active_count)"')

  local selected=$(printf '%s\n' "${items[@]}" \
    | fzf --with-nth=2.. --delimiter=$'\t' --height=40% --reverse --prompt="Repository> ")
  if [[ -n "$selected" ]]; then
    printf '%s\n' "$selected" | cut -f1
  fi
}

# Issue / ワークスペース選択 (階層 + ページング + リポジトリ横断)
#   _pick_workspace repo <ns_repo>  … リポジトリ起点 (main を含む従来ビュー)
#   _pick_workspace group <id>      … repo-group 起点 (グループ横断の Issue 一覧)
# 行はサーバー応答の repo を保持し、選択結果は "repo\tid" で返す
# (クロスリポジトリの子 Issue はその所属リポジトリで開くため)。
# has_children (▸) の Issue を選ぶと子の一覧に降り、next_cursor がある階層は
# 「… さらに読み込む」でページを足す。group のトップレベルが空
# (トラッカー非対応 or open Issue なし) のときは __fallback__ を返し、
# 呼び出し側は従来のリポジトリ起点フローに落ちる。
_pick_workspace() {
  local mode=$1 arg=$2 group_tracker=${3:-}
  local TAB=$'\t'
  local -a parents=()  # ドリルダウンの親スタック ("repo|id")
  local -a acc=()      # 現在の階層で読み込み済みの行
  local cursor="" fetch_cursor="" need_fetch=1
  local ctx_repo=""    # 現在の階層の基準リポジトリ (違う repo の行に repo# を付ける)

  while true; do
    if (( need_fetch )); then
      local -a query=()
      if (( ${#parents[@]} > 0 )); then
        local top=${parents[-1]}
        ctx_repo=${top%%|*}
        query=(list-issues --repo "$ctx_repo" --parent "${top#*|}")
      elif [[ "$mode" == "group" ]]; then
        ctx_repo=""
        query=(list-group-issues --group "$arg")
        [[ -n "$group_tracker" && "$group_tracker" != "-" ]] && query+=(--tracker "$group_tracker")
      else
        ctx_repo=$arg
        query=(list-issues --repo "$arg")
      fi
      [[ -n "$fetch_cursor" ]] && query+=(--cursor "$fetch_cursor")
      local json=$(_server "${query[@]}")

      while IFS=$'\t' read -r id title repo active closed dc children orphan; do
        [[ -n "$id" ]] || continue
        # マーカーは行頭に出す (行末だと長いタイトルの切り詰めで見えなくなる)。
        # ▸ = 子 Issue あり、↳ = 一覧の外から浮上した作業中の workspace
        # (階層の一部ではない)
        local marker="  "
        [[ "$children" == "true" ]] && marker="▸ "
        [[ "$orphan" == "true" ]] && marker="↳ "
        local display=""
        if [[ "$id" == "main" ]]; then
          display="${marker}main  (ディスカッション・調査用)"
        elif [[ "$repo" != "$ctx_repo" ]]; then
          display="${marker}${repo}#${id}  ${title}"
        else
          display="${marker}#${id}  ${title}"
        fi
        if [[ "$closed" == "true" ]]; then
          display+="  ✔ closed"
        fi
        if [[ "$active" == "true" ]]; then
          display+="  ● active"
        fi
        local dc_disp=$(_dc_indicator "$dc")
        [[ -n "$dc_disp" ]] && display+="  ${dc_disp}"
        acc+=("${repo}${TAB}${id}${TAB}${display}${TAB}${children}")
      done < <(printf '%s\n' "$json" \
        | jq -r '.issues[] | "\(.id)\t\(.title)\t\(.repo)\t\(.active)\t\(.closed)\t\(.devcontainer // "none")\t\(.has_children // false)\t\(.orphan // false)"')

      cursor=$(printf '%s\n' "$json" | jq -r '.next_cursor // empty')
      need_fetch=0
      fetch_cursor=""

      # group のトップレベルが空 → リポジトリ起点フローへ
      if [[ "$mode" == "group" && ${#parents[@]} -eq 0 && ${#acc[@]} -eq 0 && -z "$cursor" ]]; then
        echo "__fallback__"
        return 0
      fi
    fi

    local header=""
    if [[ "$mode" == "group" ]]; then
      header="repo-group ${arg}"
    else
      header="$arg"
    fi
    local p
    for p in "${parents[@]}"; do header+="  ${p%%|*}#${p#*|} >"; done

    local items=()
    if (( ${#parents[@]} > 0 )); then
      local top=${parents[-1]}
      items+=("-${TAB}__self__${TAB}  (この Issue #${top#*|} を開く)")
      items+=("-${TAB}__up__${TAB}  ..")
    fi
    items+=("${acc[@]}")
    [[ -n "$cursor" ]] && items+=("-${TAB}__more__${TAB}  … さらに読み込む")

    local selected=$(printf '%s\n' "${items[@]}" \
      | fzf --with-nth=3 --delimiter=$'\t' --height=40% --reverse --prompt="Issue> " --header="$header")
    [[ -z "$selected" ]] && return 0

    local sel_repo=$(printf '%s\n' "$selected" | cut -f1)
    local sel_id=$(printf '%s\n' "$selected" | cut -f2)
    local sel_children=$(printf '%s\n' "$selected" | cut -f4)
    case "$sel_id" in
      __self__)
        local top=${parents[-1]}
        printf '%s\t%s\n' "${top%%|*}" "${top#*|}"
        return 0
        ;;
      __up__)
        parents=("${parents[@]:0:${#parents[@]}-1}")
        acc=() cursor="" need_fetch=1
        ;;
      __more__)
        fetch_cursor=$cursor
        cursor=""
        need_fetch=1
        ;;
      *)
        if [[ "$sel_children" == "true" ]]; then
          parents+=("${sel_repo}|${sel_id}")
          acc=() cursor="" need_fetch=1
        else
          printf '%s\t%s\n' "$sel_repo" "$sel_id"
          return 0
        fi
        ;;
    esac
  done
}

# Issue 選択後の作業リポジトリ選択。既定 (先頭) は Issue の所属リポジトリで、
# 同じ repo-group のローカルにあるリポジトリを代わりに選べる。
# 所属リポジトリがローカルにない (アンブレラ等、Issue だけの置き場) ときは
# 候補から外す — 選んでも開けないため。候補が 1 つならそれで確定する。
_pick_work_repo() {
  local group_id=$1 home_repo=$2 group_tracker=${3:-}
  local TAB=$'\t'

  local -a query=(list-repos --group "$group_id")
  [[ -n "$group_tracker" && "$group_tracker" != "-" ]] && query+=(--tracker "$group_tracker")
  local json=$(_server "${query[@]}")
  local items=() home_local=false
  local repo active_count
  while IFS=$'\t' read -r repo active_count; do
    [[ -n "$repo" ]] || continue
    local display="$repo"
    if [[ "$active_count" -gt 0 ]]; then
      display+="  (${active_count} workspaces)"
    fi
    if [[ "$repo" == "$home_repo" ]]; then
      home_local=true
      items=("${repo}${TAB}${display}  (この Issue のリポジトリ)" "${items[@]}")
    else
      items+=("${repo}${TAB}${display}")
    fi
  done < <(printf '%s\n' "$json" | jq -r '.[] | "\(.ns_repo)\t\(.active_count)"')

  local header="Issue の所属: ${home_repo}"
  [[ "$home_local" == false ]] && header+="  (ローカルになし)"

  if (( ${#items[@]} == 0 )); then
    echo "No local repositories in this group" >&2
    return 1
  fi
  if (( ${#items[@]} == 1 )); then
    printf '%s\n' "${items[1]}" | cut -f1
    return 0
  fi
  local selected=$(printf '%s\n' "${items[@]}" \
    | fzf --with-nth=2.. --delimiter=$'\t' --height=40% --reverse \
          --prompt="Work repo> " --header="$header")
  [[ -n "$selected" ]] && printf '%s\n' "$selected" | cut -f1
}

# 作業リポジトリが Issue の所属リポジトリと違うときの workspace id。
# 所属リポジトリ名を接頭辞にした修飾 id (api-42) を導出する
# (作業先リポジトリ自身の同番号 Issue と衝突させない。id の文法に
# 収まるよう、リポジトリ名の英数と - 以外は - に潰す)。
_workspace_id_for() {
  local home_repo=$1 work_repo=$2 issue_id=$3
  if [[ "$work_repo" == "$home_repo" || "$issue_id" == "main" ]]; then
    printf '%s\n' "$issue_id"
  else
    local base=${home_repo##*/}
    base=${base//[^A-Za-z0-9-]/-}
    printf '%s-%s\n' "$base" "$issue_id"
  fi
}

# Multi-select fzf picker for devcontainer configs.
# Echoes selected config paths separated by newlines (empty = no container).
_pick_devcontainer() {
  local ns_repo=$1 id=$2
  local TAB=$'\t'

  local json=$(_server list-devcontainer-configs --repo "$ns_repo" --issue "$id")
  local count=$(printf '%s\n' "$json" | jq 'length')

  if [[ "$count" -eq 0 ]]; then
    echo "No devcontainer configs available" >&2
    return 0
  fi

  local items=("(none)${TAB}none${TAB}(no devcontainer)")
  # Note: avoid `path` as a variable name — it is tied to $PATH in zsh.
  local cfg_path cfg_name cfg_source
  while IFS=$'\t' read -r cfg_path cfg_name cfg_source; do
    items+=("${cfg_path}${TAB}${cfg_name}${TAB}[${cfg_source}] ${cfg_name}  ${cfg_path}")
  done < <(printf '%s\n' "$json" | jq -r '.[] | "\(.path)\t\(.name)\t\(.source)"')

  local selected=$(printf '%s\n' "${items[@]}" \
    | fzf --multi --with-nth=3.. --delimiter=$'\t' --height=40% --reverse \
          --prompt="Container (TAB=multi)> " --header="${ns_repo} #${id}")
  [[ -z "$selected" ]] && return 0

  # If "(none)" is among the picks, ignore everything else.
  if printf '%s\n' "$selected" | grep -q '^(none)\t'; then
    return 0
  fi

  printf '%s\n' "$selected" | cut -f1
}

# wsm rm 用: 全リポジトリの既存ワークスペースから選択
_pick_rm() {
  local TAB=$'\t'
  local json=$(_server list-workspaces)
  local count=$(printf '%s\n' "$json" | jq 'length')

  if [[ "$count" -eq 0 ]]; then
    echo "No active workspaces to remove" >&2
    return 1
  fi

  local items=()
  while IFS=$'\t' read -r repo id title active closed dc; do
    local display="${repo}"
    if [[ "$id" == "main" ]]; then
      display+="  main"
    else
      display+="  #${id}  ${title}"
    fi
    if [[ "$closed" == "true" ]]; then
      display+="  ✔ closed"
    fi
    if [[ "$active" == "true" ]]; then
      display+="  ● active"
    fi
    local dc_disp=$(_dc_indicator "$dc")
    [[ -n "$dc_disp" ]] && display+="  ${dc_disp}"
    items+=("${repo}${TAB}${id}${TAB}${display}")
  done < <(printf '%s\n' "$json" | jq -r '.[] | "\(.ns_repo)\t\(.id)\t\(.title)\t\(.active)\t\(.closed)\t\(.devcontainer // "none")"')

  local selected=$(printf '%s\n' "${items[@]}" \
    | fzf --with-nth=3.. --delimiter=$'\t' --height=40% --reverse --prompt="wsm rm> ")
  if [[ -n "$selected" ]]; then
    # ns_repo\ttarget_id を返す
    printf '%s\n' "$selected" | cut -f1,2
  fi
}

# wsm ls: 全リポジトリの既存ワークスペースを一覧表示
_do_ls() {
  local json=$(_server list-workspaces)
  local count=$(printf '%s\n' "$json" | jq 'length')

  if [[ "$count" -eq 0 ]]; then
    echo "No active workspaces"
    return
  fi

  # Group by ns_repo and display
  local prev_repo=""
  printf '%s\n' "$json" | jq -r '.[] | "\(.ns_repo)\t\(.id)\t\(.title)\t\(.active)\t\(.closed)\t\(.devcontainer // "none")"' | \
  while IFS=$'\t' read -r repo id title active closed dc; do
    if [[ "$repo" != "$prev_repo" ]]; then
      [[ -n "$prev_repo" ]] && echo ""
      echo "${repo}:"
      prev_repo="$repo"
    fi

    local line=""
    if [[ "$id" == "main" ]]; then
      line="  main  (ディスカッション・調査用)"
    else
      line="  #${id}  ${title}"
    fi

    if [[ "$closed" == "true" ]]; then
      line+="  ✔ closed"
    fi
    if [[ "$active" == "true" ]]; then
      line+="  ● active"
    fi
    local dc_disp=$(_dc_indicator "$dc")
    [[ -n "$dc_disp" ]] && line+="  ${dc_disp}"
    printf '%s\n' "$line"
  done

  echo ""
}

# wsm doctor: 構成の健全性を一望する。
# server 到達性・セッションマネージャー・トラッカー (installed / ready /
# 診断)・UI の依存コマンドを表示する。状態の解釈は server の JSON をそのまま
# 使い、UI は整形だけを行う。
_do_doctor() {
  # server 到達性
  case "$WSM_TRANSPORT" in
    local)
      local server_path=$(command -v wsm-server || true)
      if [[ -n "$server_path" ]]; then
        echo "server            ✅ ${server_path} (local)"
      else
        echo "server            ❌ wsm-server not found in PATH"
        return 1
      fi
      ;;
    ssh)
      if _server list-session-managers >/dev/null 2>&1; then
        echo "server            ✅ ${HOST_USER}@${WSM_HOST} (ssh)"
      else
        echo "server            ❌ unreachable: ${HOST_USER}@${WSM_HOST} (ssh)"
        return 1
      fi
      ;;
  esac

  # セッションマネージャー (設定済みのものと既定)
  echo "session managers"
  local sm_json=$(_server list-session-managers)
  if [[ $(printf '%s\n' "$sm_json" | jq 'length') -eq 0 ]]; then
    echo "  (none)          ❌ config.toml に tmux_path / herdr_path を設定"
  else
    local name is_default
    while IFS=$'\t' read -r name is_default; do
      local mark=""
      [[ "$is_default" == "true" ]] && mark="  (既定)"
      printf '  %-16s✅ 設定済み%s\n' "$name" "$mark"
    done < <(printf '%s\n' "$sm_json" | jq -r '.[] | "\(.name)\t\(.default)"')
  fi

  # トラッカー (installed / ready / 診断)
  echo "trackers"
  local tr_json=$(_server list-trackers)
  if [[ $(printf '%s\n' "$tr_json" | jq 'length') -eq 0 ]]; then
    echo "  (none)          ❌ config.toml に [[tracker]] を追加"
  else
    # Note: `status` は zsh の読み取り専用変数 ($? の別名) のため使わない
    local tr_path installed ready diagnosis health
    while IFS=$'\t' read -r name is_default tr_path installed ready diagnosis; do
      local label=$name
      [[ "$is_default" == "true" ]] && label+=" (既定)"
      if [[ "$installed" != "true" ]]; then
        health="❌ not installed: ${tr_path}"
      elif [[ "$ready" == "true" ]]; then
        health="✅ ready"
      elif [[ "$ready" == "false" ]]; then
        health="⚠️  not ready: ${diagnosis}"
      else
        health="✅ installed (info-v0 非対応)"
      fi
      printf '  %-16s%s\n' "$label" "$health"
    # diagnosis は複数行になり得る (gh の stderr パススルー)。1 行表示に潰す
    done < <(printf '%s\n' "$tr_json" \
      | jq -r '.[] | "\(.name)\t\(.default)\t\(.path)\t\(.installed)\t\(.ready)\t\((.diagnosis // "") | gsub("\n"; " "))"')
  fi

  # UI の依存コマンド
  local deps=(fzf jq) missing=() ok=()
  [[ "$WSM_TRANSPORT" == "ssh" ]] && deps+=(ssh)
  local dep
  for dep in "${deps[@]}"; do
    if command -v "$dep" >/dev/null 2>&1; then ok+=("$dep"); else missing+=("$dep"); fi
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "deps              ❌ missing: ${missing[*]}"
  else
    echo "deps              ✅ ${ok[*]}"
  fi
}

# --- Main ---

_check_deps

# セッションマネージャーの既定はホスト側の config.toml で決まる (core が読む)。
# 環境変数 WSM_SESSION_MANAGER はその場のオーバーライドで、-m フラグや
# fzf での選択時のみ export してローカル実行の core に伝える (SSH では伝わらない)。
[[ -n "${WSM_SESSION_MANAGER:-}" ]] && export WSM_SESSION_MANAGER

cmd=${1:-}
shift 2>/dev/null || true

case "$cmd" in
  "op")
    target="" with_devcontainer=false manager_set=false
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -d|--devcontainer) with_devcontainer=true; shift ;;
        -m|--manager) export WSM_SESSION_MANAGER=$2; manager_set=true; shift 2 ;;
        *) target=$1; shift ;;
      esac
    done
    [[ "$WSM_TRANSPORT" == "ssh" && "$manager_set" == true ]] && _warn_manager_over_ssh

    ns_repo="" issue_id=""
    if [[ -z "$target" ]]; then
      if [[ "$WSM_TRANSPORT" == "local" && "$manager_set" == false ]]; then
        selected_manager=$(_pick_session_manager)
        [[ -z "$selected_manager" ]] && exit 0
        export WSM_SESSION_MANAGER=$selected_manager
      fi

      # 段階選択 (Issue 起点): repo-group → Issue → 作業リポジトリ → DevContainer。
      # 「グループなし」とグループの Issue 一覧が空のときは従来の
      # リポジトリ起点 (リポジトリ → Issue) に落ちる
      group_sel=$(_pick_repo_group)
      [[ -z "$group_sel" ]] && exit 0
      group_tracker=${group_sel%%$'\t'*}
      group_id=${group_sel#*$'\t'}

      selection=""
      if [[ "$group_id" != "none" ]]; then
        selection=$(_pick_workspace group "$group_id" "$group_tracker")
        [[ -z "$selection" ]] && exit 0
      fi

      if [[ -z "$selection" || "$selection" == "__fallback__" ]]; then
        # リポジトリ起点フロー
        ns_repo=$(_pick_repo "$group_id")
        [[ -z "$ns_repo" ]] && exit 0
        selection=$(_pick_workspace repo "$ns_repo")
        [[ -z "$selection" || "$selection" == "__fallback__" ]] && exit 0
        home_repo=${selection%%$'\t'*}
        issue_id=${selection#*$'\t'}
        # クロスリポジトリの子 Issue はその所属リポジトリで開く
        ns_repo=$home_repo
      else
        home_repo=${selection%%$'\t'*}
        issue_id=${selection#*$'\t'}
        ns_repo=$(_pick_work_repo "$group_id" "$home_repo" "$group_tracker")
        [[ -z "$ns_repo" ]] && exit 0
        issue_id=$(_workspace_id_for "$home_repo" "$ns_repo" "$issue_id")
      fi

      with_devcontainer=true
    else
      resolved=$(_resolve_target "$target") || exit 1
      ns_repo=${resolved%%$'\t'*}
      issue_id=${resolved#*$'\t'}
    fi

    open_args=()
    if [[ "$with_devcontainer" == true ]]; then
      picked=$(_pick_devcontainer "$ns_repo" "$issue_id") || exit 1
      if [[ -n "$picked" ]]; then
        while IFS= read -r cfg; do
          [[ -n "$cfg" ]] && open_args+=(--config "$cfg")
        done <<< "$picked"
      fi
    fi

    result=$(_server open --repo "$ns_repo" --issue "$issue_id" "${open_args[@]}")
    printf '%s\n' "$result" | jq -r '.message // .error'
    [[ $(printf '%s\n' "$result" | jq -r '.status // empty') == "ok" ]] || exit 1

    if _terminal_available; then
      attach_command=$(printf '%s\n' "$result" | jq -r '.attach_command // empty')
      [[ -n "$attach_command" ]] && _open_terminal_tab "$attach_command"
    fi
    ;;

  "rm")
    target="" manager_set=false
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -m|--manager) export WSM_SESSION_MANAGER=$2; manager_set=true; shift 2 ;;
        *) target=$1; shift ;;
      esac
    done
    [[ "$WSM_TRANSPORT" == "ssh" && "$manager_set" == true ]] && _warn_manager_over_ssh

    if [[ -n "$target" ]]; then
      resolved=$(_resolve_target "$target") || exit 1
      ns_repo=${resolved%%$'\t'*}
      target_id=${resolved#*$'\t'}
    else
      # 既存ワークスペースから選択して削除
      selected=$(_pick_rm)
      [[ -z "$selected" ]] && exit 0

      ns_repo=${selected%%$'\t'*}
      target_id=${selected#*$'\t'}
    fi

    result=$(_server remove --repo "$ns_repo" --issue "$target_id")
    printf '%s\n' "$result" | jq -r '.message // .error'
    ;;

  "ls")
    manager_set=false
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -m|--manager) export WSM_SESSION_MANAGER=$2; manager_set=true; shift 2 ;;
        *) shift ;;
      esac
    done
    [[ "$WSM_TRANSPORT" == "ssh" && "$manager_set" == true ]] && _warn_manager_over_ssh
    _do_ls
    ;;

  "doctor")
    _do_doctor
    ;;

  *)
    echo "Usage: wsm <op|rm|ls|doctor>"
    echo ""
    echo "  wsm op [-d] [-m tmux|herdr] [<id>|<ns>/<repo>#<id>]   Open workspace"
    echo "                                        (-d: pick devcontainer(s))"
    echo "                                        bare <id>: cwd-resolved repo"
    echo "  wsm rm [-m tmux|herdr] [<id>|<ns>/<repo>#<id>]        Remove workspace"
    echo "  wsm ls [-m tmux|herdr]                                List workspaces"
    echo "  wsm doctor                                            Check configuration health"
    ;;
esac
